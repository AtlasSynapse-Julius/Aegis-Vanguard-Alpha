# Aegis Vanguard — copy this file to .env and fill in your values
# Do not commit .env (it contains secrets).

# Database (default works with docker compose)
DATABASE_URL=postgresql://aegis:aegis@postgres:5432/aegis

# Gemini API key (for scanner attack generation and evaluation)
GEMINI_API_KEY=

# Optional: Claude/Anthropic (if set, scanner uses Claude instead of Gemini)
# ANTHROPIC_API_KEY=

# Server
PORT=4000
NODE_ENV=production

# Authentication — set a strong password and secret in production
ADMIN_PASSWORD=change-me
JWT_SECRET=change-me-to-a-long-random-string
